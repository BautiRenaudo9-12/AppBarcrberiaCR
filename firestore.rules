rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      // Admins "semilla" hardcodeados (deben coincidir con VITE_ADMIN_EMAILS en el cliente).
      // Se pueden agregar más admins sin editar reglas creando un doc en `admins/{email}`
      // desde la consola de Firebase. Los hardcodeados quedan como fallback para no
      // arriesgar un lockout si la colección no existe.
      return isSignedIn() && (
        request.auth.token.email == 'renaudobautista@gmail.com' ||
        request.auth.token.email == 'barberiaclaudiorenaudo@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
      );
    }

    function isOwner(email) {
      return isSignedIn() && request.auth.token.email == email;
    }

    // --- Rules ---

    // Clientes: Stricter rules for better security
    match /clientes/{email} {
      // READ: 
      // - Get (single doc): Owner or Admin
      // - List (queries): Only Admin can list/search clients
      allow get: if isOwner(email) || isAdmin();
      allow list: if isAdmin();

      // CREATE: User can create their own profile.
      // Enforce data integrity: email field must match document ID.
      allow create: if isOwner(email) 
                    && request.resource.data.email == email;

      // UPDATE: User can update their own data.
      // Security check: Prevent changing the 'email' field to mismatch the ID.
      // This allows updating name, phone, keywords, fcmToken, reserve, etc.
      allow update: if isAdmin() || (
        isOwner(email) && request.resource.data.email == email
      );

      // DELETE: Only Admin can delete users (prevent accidental self-deletion)
      allow delete: if isAdmin();
      
      // Subcollection History (Legacy/Backup)
      match /history/{historyId} {
        allow read, write: if isOwner(email) || isAdmin();
      }
    }

    // Turnos: Publicly readable. 
    // Admins manage structure. 
    // Users can "update" a specific turno to reserve it.
    match /turnos/{day} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      
      match /turnos/{turnoId} {
        allow read: if isSignedIn();
        // Solo admin escribe la config de slots. El flujo de reserva de clientes ya no
        // toca `turnos`: vive en la colección `appointments`.
        allow write: if isAdmin();
      }
    }

    // Anuncios: Public read for signed users, Admin write.
    match /anuncios/{anuncioId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Appointments: Core logic for new architecture
    match /appointments/{appointmentId} {
      // Users need to read appointments to know which slots are taken (availability)
      allow read: if isSignedIn();
      
      // Users can create if they sign it with their own email
      allow create: if isSignedIn() && request.resource.data.clientEmail == request.auth.token.email;
      
      // Users can delete (cancel) their own
      allow delete: if isAdmin() || (isSignedIn() && resource.data.clientEmail == request.auth.token.email);
      
      // Only admins can update (e.g. change status) for now
      allow update: if isAdmin();
    }

    // Blocked Slots: Admin managed, User readable for availability
    match /blocked_slots/{slotId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // Exceptions: Admin managed (to activate blocked slots), User readable
    match /slot_exceptions/{exceptionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // Lista de espera: el cliente gestiona (crea/lee/borra) solo sus propias entradas;
    // el admin puede leer todo. `lastNotifiedAt` lo escribe el server (Admin SDK, saltea
    // reglas), por eso no habilitamos update desde el cliente.
    match /waitlist/{entryId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.clientEmail == request.auth.token.email);
      allow create: if isSignedIn() && request.resource.data.clientEmail == request.auth.token.email;
      allow delete: if isAdmin() || (isSignedIn() && resource.data.clientEmail == request.auth.token.email);
    }

    // Config global (ej. `config/booking`: rango máximo de días para reservar).
    // Lectura para cualquier usuario logueado (el cliente la necesita para el selector
    // de fecha); escritura solo admin.
    match /config/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Admins: lista opcional de admins adicionales (ver isAdmin()). Se gestiona desde la
    // consola de Firebase; el cliente nunca escribe acá.
    match /admins/{email} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Default: Deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
