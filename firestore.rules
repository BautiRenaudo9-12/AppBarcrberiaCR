rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      // Admins "semilla" hardcodeados (deben coincidir con VITE_ADMIN_EMAILS en el cliente).
      // Se pueden agregar más admins sin editar reglas creando un doc en `admins/{email}`
      // desde la consola de Firebase. Los hardcodeados quedan como fallback para no
      // arriesgar un lockout si la colección no existe.
      return isSignedIn() && (
        request.auth.token.email == 'renaudobautista@gmail.com' ||
        request.auth.token.email == 'barberiaclaudiorenaudo@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
      );
    }

    function isOwner(email) {
      return isSignedIn() && request.auth.token.email == email;
    }

    // --- Rules ---

    // Clientes: Stricter rules for better security
    match /clientes/{email} {
      // READ: 
      // - Get (single doc): Owner or Admin
      // - List (queries): Only Admin can list/search clients
      allow get: if isOwner(email) || isAdmin();
      allow list: if isAdmin();

      // CREATE: User can create their own profile.
      // Enforce data integrity: email field must match document ID.
      allow create: if isOwner(email) 
                    && request.resource.data.email == email;

      // UPDATE: User can update their own data.
      // Security check: Prevent changing the 'email' field to mismatch the ID.
      // This allows updating name, phone, keywords, fcmToken, reserve, etc.
      allow update: if isAdmin() || (
        isOwner(email) && request.resource.data.email == email
      );

      // DELETE: Only Admin can delete users (prevent accidental self-deletion)
      allow delete: if isAdmin();
      
      // Subcollection History (Legacy/Backup)
      match /history/{historyId} {
        allow read, write: if isOwner(email) || isAdmin();
      }
    }

    // Turnos: Publicly readable. 
    // Admins manage structure. 
    // Users can "update" a specific turno to reserve it.
    match /turnos/{day} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      
      match /turnos/{turnoId} {
        allow read: if isSignedIn();
        // Solo admin escribe la config de slots. El flujo de reserva de clientes ya no
        // toca `turnos`: vive en la colección `appointments`.
        allow write: if isAdmin();
      }
    }

    // Anuncios: Public read for signed users, Admin write.
    match /anuncios/{anuncioId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Appointments: Core logic for new architecture
    match /appointments/{appointmentId} {

      // La ID del doc es determinista ("2026-01-16_10-00") y ES el mecanismo que evita el
      // doble-booking: dos reservas del mismo slot colisionan en la misma ID. Si el cliente
      // pudiera elegir una ID que no se corresponde con la fecha/hora que guarda, esquivaría
      // esa colisión y podría reservar un turno ya tomado.
      function idMatchesSlot() {
        return appointmentId ==
          request.resource.data.date + "_" + request.resource.data.time.replace(":", "-");
      }

      // Validación de forma del turno nuevo. `hasOnly` corta la inyección de campos que el
      // cliente no debería escribir (p. ej. `notified` o `clientConfirmed`, que son del
      // servidor). Falla cerrado a propósito: si algún día se agrega un campo a la reserva
      // hay que sumarlo acá, y mientras tanto ninguna reserva se crea a medias.
      function validNewAppointment() {
        let d = request.resource.data;
        return d.keys().hasOnly(
                 ['date', 'time', 'timestamp', 'clientEmail', 'clientName', 'status', 'createdAt']
               )
               && d.date is string && d.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
               && d.time is string && d.time.matches('^([01][0-9]|2[0-3]):[0-5][0-9]$')
               && d.timestamp is timestamp
               && d.createdAt is timestamp
               && d.status == 'confirmed'
               && d.clientName is string
               // El tope es holgado a propósito: acá el objetivo es frenar basura, no validar
               // nombres. Si queda justo, un nombre largo hace fallar la reserva —la acción
               // central de la app— con un error genérico e indescifrable. Los formularios
               // limitan a 80, así que 120 deja margen para lo que ya esté guardado.
               && d.clientName.size() > 0 && d.clientName.size() <= 120
               && idMatchesSlot();
      }

      // Users need to read appointments to know which slots are taken (availability).
      // LIMITACIÓN ACEPTADA: esto expone `clientEmail`/`clientName` de todos los turnos a
      // cualquier usuario logueado. Las reglas no filtran por campo; ocultarlos exigiría una
      // colección paralela con la disponibilidad sin datos personales.
      allow read: if isSignedIn();

      // Users can create if they sign it with their own email.
      // LIMITACIÓN ACEPTADA: el tope de "un turno activo por cliente" NO se impone acá. Las
      // reglas pueden leer un doc puntual (`get`) pero no hacer queries, y cualquier puntero
      // que guardáramos en `clientes/{email}` lo puede borrar el propio cliente. Cerrarlo de
      // verdad requiere crear las reservas desde una function con Admin SDK.
      // `validNewAppointment()` va PRIMERO y `isAdmin()` queda de fallback: el orden importa
      // en plata. isAdmin() termina en un exists(/admins/{email}), que se factura como lectura;
      // evaluándolo primero, CADA reserva de CADA cliente pagaba esa lectura extra. Los
      // walk-ins del admin escriben exactamente la misma forma, así que también pasan por
      // validación y el exists() casi nunca llega a ejecutarse.
      allow create: if isSignedIn()
                    && request.resource.data.clientEmail == request.auth.token.email
                    && (validNewAppointment() || isAdmin());

      // Users can delete (cancel) their own
      allow delete: if isAdmin() || (isSignedIn() && resource.data.clientEmail == request.auth.token.email);
      
      // Only admins can update (e.g. change status) for now
      allow update: if isAdmin();
    }

    // Blocked Slots: Admin managed, User readable for availability
    match /blocked_slots/{slotId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // Exceptions: Admin managed (to activate blocked slots), User readable
    match /slot_exceptions/{exceptionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Closures: cierres por rango de fechas (vacaciones). Admin gestiona, usuario lee
    // (necesario para calcular disponibilidad y ocultar los días cerrados).
    match /closures/{closureId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // Lista de espera: el cliente gestiona (crea/lee/borra) solo sus propias entradas;
    // el admin puede leer todo. `lastNotifiedAt` lo escribe el server (Admin SDK, saltea
    // reglas), por eso no habilitamos update desde el cliente.
    match /waitlist/{entryId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.clientEmail == request.auth.token.email);
      allow create: if isSignedIn() && request.resource.data.clientEmail == request.auth.token.email;
      allow delete: if isAdmin() || (isSignedIn() && resource.data.clientEmail == request.auth.token.email);
    }

    // Config global (ej. `config/booking`: rango máximo de días para reservar).
    // Lectura para cualquier usuario logueado (el cliente la necesita para el selector
    // de fecha); escritura solo admin.
    match /config/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Admins: lista opcional de admins adicionales (ver isAdmin()). Se gestiona desde la
    // consola de Firebase; el cliente nunca escribe acá.
    match /admins/{email} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Default: Deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
